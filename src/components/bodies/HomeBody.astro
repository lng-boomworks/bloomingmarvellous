---
import { withBase } from '../../utils/url';
import { localizedPath, type Locale } from '../../i18n/ui';
import { useContent } from '../../i18n/content';
import { site, occasionIds, occasionImages, reviews } from '../../data/site';
import LogoLockup from '../LogoLockup.astro';
import ValueProps from '../ValueProps.astro';
import OccasionCard from '../OccasionCard.astro';
import Sprig from '../Sprig.astro';
import Testimonial from '../Testimonial.astro';
import DeliveryAreas from '../DeliveryAreas.astro';
import CTABand from '../CTABand.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const c = useContent(locale);
const h = c.home;
const flowersHref = localizedPath('flowers', locale);
const homeReviews = [reviews.vivien, reviews.martin, reviews.elise];
const andrea = reviews.andrea;
---

<!-- Hero -->
<section class="relative grid lg:grid-cols-2 min-h-[94vh]">
  <div class="relative order-2 lg:order-1 min-h-[45vh] lg:min-h-full">
    <img src={withBase('/images/hero.jpg')} alt="A lush bouquet of peonies, roses and tulips with eucalyptus" class="absolute inset-0 w-full h-full object-cover" />
  </div>
  <div class="order-1 lg:order-2 flex items-center justify-center bg-ivory px-6 py-28 lg:py-0">
    <div class="max-w-xl text-center">
      <LogoLockup size="lg" />
      <div class="mt-8 space-y-1">
        <p class="font-serif font-medium uppercase tracking-wide text-charcoal text-3xl md:text-4xl">{h.heroLine1}</p>
        <p class="font-serif font-medium uppercase tracking-wide text-rose text-3xl md:text-4xl">{h.heroLine2}</p>
        <p class="script text-rose text-5xl md:text-6xl">{h.heroLine3Script}</p>
      </div>
      <p class="mt-7 text-text-muted text-lg leading-relaxed max-w-md mx-auto">{h.heroSub}</p>
      <div class="flex flex-wrap gap-4 justify-center mt-9">
        <a href={site.whatsappHref} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md bg-rose text-white font-medium hover:bg-rose-hover transition-colors shadow-sm">
          {c.shared.orderWhatsapp}
        </a>
        <a href={flowersHref}
           class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-rose text-rose font-medium hover:bg-rose hover:text-white transition-colors">
          {c.shared.seeFlowers}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Value props -->
<section class="bg-cream section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <ValueProps locale={locale} />
  </div>
</section>

<!-- Intro -->
<section class="section">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="eyebrow mb-4">{h.introEyebrow}</p>
    <h2>{h.introHeading}</h2>
    <p class="mt-6 text-text-muted text-lg leading-relaxed">{h.introBody}</p>
    <Sprig class="mt-10" />
  </div>
</section>

<!-- Occasions -->
<section class="bg-dusty/30 section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="eyebrow mb-4">{h.occasionsEyebrow}</p>
      <h2>{h.occasionsHeading}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {occasionIds.map((id) => (
        <OccasionCard
          image={occasionImages[id]}
          title={c.occasions[id].title}
          blurb={c.occasions[id].blurb}
          alt={c.occasions[id].title}
        />
      ))}
    </div>
  </div>
</section>

<!-- Featured / bespoke story -->
<section class="section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class="order-2 lg:order-1">
      <p class="eyebrow mb-4">{h.featuredEyebrow}</p>
      <h2>{h.featuredHeading}</h2>
      <p class="mt-6 text-text-muted text-lg leading-relaxed">{h.featuredBody}</p>
      <blockquote class="mt-8 border-l-2 border-gold pl-6 font-serif italic text-xl text-botanical leading-relaxed">
        “{andrea.quote}”
        <cite class="block not-italic font-sans text-sm text-text-muted mt-3">— {andrea.author}</cite>
      </blockquote>
    </div>
    <div class="order-1 lg:order-2">
      <img src={withBase('/images/featured.jpg')} alt="A bespoke hand-made floral arrangement" class="w-full rounded-2xl object-cover aspect-[4/5] shadow-[0_8px_30px_rgba(0,0,0,0.08)]" />
    </div>
  </div>
</section>

<!-- Delivery promise -->
<section class="bg-cream section">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="eyebrow mb-4">{h.deliveryEyebrow}</p>
    <h2>{h.deliveryHeading}</h2>
    <p class="mt-6 text-text-muted text-lg leading-relaxed max-w-2xl mx-auto">{h.deliveryBody}</p>
    <div class="mt-10">
      <DeliveryAreas variant="chips" />
    </div>
    <div class="mt-12">
      <span class="script text-gold text-4xl block">{h.orderEaseScript}</span>
      <span class="font-serif uppercase tracking-[0.2em] text-botanical text-xl mt-1 block">{h.orderEaseLine}</span>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="eyebrow mb-4">{h.testimonialsEyebrow}</p>
      <h2>{h.testimonialsHeading}</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {homeReviews.map((r) => <Testimonial quote={r.quote} author={r.author} date={r.date} />)}
    </div>
  </div>
</section>

<CTABand locale={locale} script={h.finalScript} heading={h.finalHeading} sub={h.finalSub} />
