---
import { withBase } from '../utils/url';
import { navOrder, navLabels, localizedPath, type Locale, type RouteKey } from '../i18n/ui';
import { useContent } from '../i18n/content';
import { site } from '../data/site';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
}
const { locale, routeKey } = Astro.props;
const labels = navLabels[locale];
const t = useContent(locale).shared;
const homeHref = localizedPath('home', locale);
---
<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 border-b border-transparent"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between gap-4">
    <a href={homeHref} class="brand-mark flex items-baseline gap-2 shrink-0" aria-label="Blooming Marvellous - home">
      <span class="script text-4xl md:text-[44px] text-botanical leading-none">Blooming</span>
      <span class="font-serif uppercase tracking-[0.28em] text-rose text-base font-semibold">Marvellous</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8" aria-label="Primary">
      <ul class="flex items-center gap-7">
        {navOrder.map((key) => (
          <li>
            <a
              href={localizedPath(key, locale)}
              aria-current={key === routeKey ? 'page' : undefined}
              class={`text-[14px] font-medium tracking-wide transition-colors hover:text-rose ${key === routeKey ? 'text-rose' : 'text-botanical'}`}
            >
              {labels[key]}
            </a>
          </li>
        ))}
      </ul>
      <LanguageToggle locale={locale} routeKey={routeKey} />
      <a
        href={site.whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-rose text-white text-[14px] font-medium hover:bg-rose-hover transition-colors shadow-sm"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.2 0-.3 0-.5s-.5-1.3-.7-1.7-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.2 5.2 5.2 0 0 0 1.1 2.8 11.9 11.9 0 0 0 4.6 4 5.3 5.3 0 0 0 3.2.7 2.7 2.7 0 0 0 1.8-1.3 2.2 2.2 0 0 0 .2-1.3c0-.1-.2-.2-.4-.3z"/></svg>
        {t.orderWhatsapp}
      </a>
    </nav>

    <button
      id="nav-toggle"
      class="lg:hidden p-2 text-botanical"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="nav-icon-open" viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      <svg id="nav-icon-close" viewBox="0 0 24 24" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>

  <!-- Mobile panel -->
  <div id="nav-mobile" class="lg:hidden hidden bg-cream/98 backdrop-blur-md border-t border-border">
    <div class="px-6 py-6 flex flex-col gap-5">
      <ul class="flex flex-col gap-4">
        {navOrder.map((key) => (
          <li>
            <a
              href={localizedPath(key, locale)}
              aria-current={key === routeKey ? 'page' : undefined}
              class={`block text-lg font-medium ${key === routeKey ? 'text-rose' : 'text-botanical'}`}
            >
              {labels[key]}
            </a>
          </li>
        ))}
      </ul>
      <div class="pt-4 border-t border-border flex items-center justify-between">
        <LanguageToggle locale={locale} routeKey={routeKey} />
        <a
          href={site.whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-rose text-white text-sm font-medium"
        >
          {t.orderWhatsapp}
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const onScroll = () => {
      if (!header) return;
      header.classList.toggle('nav-solid', window.scrollY > 40);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const toggle = document.getElementById('nav-toggle');
    const panel = document.getElementById('nav-mobile');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    toggle?.addEventListener('click', () => {
      const open = panel?.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
      iconOpen?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
    });
  })();
</script>
