---
// Brand motif divider — a small gold botanical sprig flanked by hairlines.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div class={`flex items-center justify-center gap-4 text-gold ${className}`} aria-hidden="true">
  <span class="h-px w-12 bg-gold/50"></span>
  <svg viewBox="0 0 32 32" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
    <path d="M16 28V11" />
    <path d="M16 16c-3 0-5-2-5-5 3 0 5 2 5 5z" fill="currentColor" stroke="none" />
    <path d="M16 13c3 0 5-2 5-5-3 0-5 2-5 5z" fill="currentColor" stroke="none" />
    <path d="M16 20c-2.4 0-4-1.6-4-4 2.4 0 4 1.6 4 4z" fill="currentColor" stroke="none" />
    <path d="M16 18c2.4 0 4-1.6 4-4-2.4 0-4 1.6-4 4z" fill="currentColor" stroke="none" />
  </svg>
  <span class="h-px w-12 bg-gold/50"></span>
</div>
