---
import { useContent } from '../i18n/content';
import { site } from '../data/site';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  script?: string;
  heading: string;
  sub?: string;
}
const { locale, script, heading, sub } = Astro.props;
const t = useContent(locale).shared;
---
<section class="bg-botanical text-cream section">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {script && <span class="script text-gold text-4xl md:text-5xl block">{script}</span>}
    <h2 class="text-cream mt-3">{heading}</h2>
    {sub && <p class="text-cream/80 mt-5 text-lg leading-relaxed">{sub}</p>}
    <div class="flex flex-wrap gap-4 justify-center mt-9">
      <a href={site.whatsappHref} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md bg-rose text-white font-medium hover:bg-rose-hover transition-colors shadow-sm">
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.2 0-.3 0-.5s-.5-1.3-.7-1.7-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-1 2.2 5.2 5.2 0 0 0 1.1 2.8 11.9 11.9 0 0 0 4.6 4 5.3 5.3 0 0 0 3.2.7 2.7 2.7 0 0 0 1.8-1.3 2.2 2.2 0 0 0 .2-1.3c0-.1-.2-.2-.4-.3z"/></svg>
        {t.orderWhatsapp}
      </a>
      <a href={site.phoneHref}
         class="inline-flex items-center gap-2 px-7 py-3.5 rounded-md border border-cream/50 text-cream font-medium hover:bg-cream/10 transition-colors">
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
        {t.call} · {site.phoneDisplay}
      </a>
    </div>
  </div>
</section>
