---
import { withBase } from '../utils/url';
// Occasion tile — image, title, short blurb. Used on Home + Our Flowers.
interface Props {
  image: string;
  title: string;
  blurb: string;
  alt: string;
}
const { image, title, blurb, alt } = Astro.props;
---
<article class="group bg-card rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.06)] flex flex-col h-full transition-transform duration-300 hover:-translate-y-1">
  <div class="aspect-[4/3] overflow-hidden bg-dusty">
    <img
      src={withBase(image)}
      alt={alt}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="p-6 flex flex-col flex-1">
    <h3 class="font-serif text-2xl text-botanical mb-2">{title}</h3>
    <p class="text-text-muted text-[15px] leading-relaxed">{blurb}</p>
  </div>
</article>
