---
import Base from '../../layouts/Base.astro';
import ContactBody from '../../components/bodies/ContactBody.astro';
import { useContent } from '../../i18n/content';
const locale = 'es' as const;
const meta = useContent(locale).meta.contact;
---
<Base title={meta.title} description={meta.description} locale={locale} routeKey="contact">
  <ContactBody locale={locale} />
</Base>
