---
import '../styles/global.css';
import { withBase } from '../utils/url';
import { htmlLang, ogLocale, type Locale, type RouteKey } from '../i18n/ui';
import { site } from '../data/site';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  routeKey?: RouteKey;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = 'Bespoke flower arrangements for every occasion, hand-made on the Costa Blanca with free local delivery.',
  locale = 'en',
  routeKey = 'home',
  ogImage = '/images/og-default.jpg',
  type = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Blooming Marvellous" />
    <meta property="og:locale" content={ogLocale[locale]} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" href={withBase("/favicon.ico")} sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Allura&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Florist / LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Florist",
      "@id": "https://bloomingmarvellousflowers.com/#business",
      "name": "Blooming Marvellous",
      "description": "Bespoke flower arrangements for every occasion, hand-made on the Costa Blanca with free local delivery.",
      "url": "https://bloomingmarvellousflowers.com",
      "telephone": "+34618063933",
      "email": site.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Virgen de la Asunción, Urbanización Oasis",
        "addressLocality": "La Marina",
        "addressRegion": "Alicante",
        "addressCountry": "ES"
      },
      "areaServed": "Costa Blanca South",
      "priceRange": "€€"
    })} />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <Navbar locale={locale} routeKey={routeKey} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} routeKey={routeKey} />
  </body>
</html>
